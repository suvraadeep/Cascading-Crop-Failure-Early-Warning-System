# Copy to .env and fill in your keys

# Twilio (SMS Alerts) — get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890    # Your Twilio number
TWILIO_TO_NUMBER=+919876543210    # Farmer's number

# Google Earth Engine — get from earthengine.google.com
GEE_PROJECT_ID=new-crop-491909
USE_GEE=true   # Set true when GEE is configured